{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.SignalR": "Information"
    }
  },
  "AllowedHosts": "*",

  



  "ConnectionStrings": {
    "DefaultConnection": ""
  },


  "JwtSettings": {
    "Key": "super secret unguessable key for abbsium software company",
    "Issuer": "Abbsium",
    "Audience": "YourAppAudience",
    "ExpiresInMinutes": "60"
  },

  

  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 60
      },
      {
        "Endpoint": "*",
        "Period": "10m",
        "Limit": 300
      },
      {
        "Endpoint": "POST:/Account/login",
        "Period": "5m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/Account/register",
        "Period": "1h",
        "Limit": 5
      }
    ]
  }

}